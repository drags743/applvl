<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="theme-color" content="#0a0a0a">
<title>Timothy LVL — Espace élève</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0a0a0a; --bg2:#111; --card:#161616; --card2:#1e1e1e; --input:#1a1a1a;
  --red:#c0392b; --red-br:#e74c3c; --red-dk:#922b21; --red-gl:rgba(192,57,43,.12);
  --txt:#f5f5f0; --txt2:#a0a09a; --txt3:#5a5a55;
  --brd:rgba(255,255,255,.07); --brd2:rgba(255,255,255,.14);
  --green:#2ecc71; --blue:#3498db; --orange:#e67e22;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--bg);color:var(--txt);overscroll-behavior:none;}
#app{display:flex;flex-direction:column;height:100vh;max-width:480px;margin:0 auto;position:relative;background:var(--bg);}

/* Screens */
.screen{display:none;position:absolute;inset:0;overflow-y:auto;overflow-x:hidden;padding-bottom:90px;-webkit-overflow-scrolling:touch;}
.screen.active{display:block;}
.screen-session{padding-bottom:100px;}
.screen-full{padding-bottom:0;}

/* Top bar */
.top-bar{padding:14px 20px 14px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px;}
.top-bar h1{font-family:'Montserrat',sans-serif;font-size:24px;font-weight:800;letter-spacing:-.01em;line-height:1.15;}
.top-bar .sub{font-size:13px;color:var(--txt3);margin-top:2px;}
.top-bar .icons{display:flex;gap:8px;}
.icon-btn{width:36px;height:36px;border-radius:50%;background:var(--card);border:1px solid var(--brd);display:flex;align-items:center;justify-content:center;color:var(--txt2);cursor:pointer;transition:.15s;}
.icon-btn:hover{background:var(--card2);color:var(--txt);}
.icon-btn svg{width:16px;height:16px;}

/* Cards */
.card{background:var(--card);border:1px solid var(--brd);border-radius:14px;padding:16px;margin:0 16px 12px;}
.card-title{font-size:12px;font-weight:600;color:var(--txt2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:6px;padding:10px 18px;border-radius:10px;font-size:13px;font-weight:600;font-family:'DM Sans',sans-serif;border:1px solid var(--brd);background:transparent;color:var(--txt);cursor:pointer;transition:.15s;}
.btn:hover{background:var(--card2);}
.btn-p{background:var(--red);border-color:var(--red);color:#fff;}
.btn-p:hover{background:var(--red-br);border-color:var(--red-br);}
.btn-sm{padding:6px 12px;font-size:11px;border-radius:8px;}
.btn-ghost{background:transparent;color:var(--red-br);border-color:var(--red-dk);}
.btn-ghost:hover{background:var(--red-gl);}
.btn-block{width:100%;justify-content:center;}

/* FAB */
.fab{position:absolute;bottom:86px;right:20px;width:54px;height:54px;border-radius:50%;background:var(--red);color:#fff;border:none;font-size:28px;font-weight:300;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 8px 20px rgba(192,57,43,.4);z-index:20;transition:.15s;}
.fab:hover{background:var(--red-br);transform:scale(1.05);}

/* Bottom nav */
#bnav{position:absolute;bottom:0;left:0;right:0;height:66px;background:#0c0c0c;border-top:1px solid var(--brd);display:flex;z-index:10;padding-bottom:env(safe-area-inset-bottom,0);}
.bnav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;color:var(--txt3);cursor:pointer;font-size:10px;font-weight:500;transition:.15s;background:none;border:none;font-family:inherit;}
.bnav-item svg{width:22px;height:22px;}
.bnav-item.active{color:var(--red-br);}

/* Date picker */
.date-row{display:flex;gap:6px;padding:0 16px 16px;overflow-x:auto;scroll-snap-type:x mandatory;}
.date-row::-webkit-scrollbar{height:0;}
.day-pill{flex-shrink:0;display:flex;flex-direction:column;align-items:center;padding:8px 10px;min-width:44px;border-radius:12px;background:transparent;border:none;cursor:pointer;font-family:inherit;scroll-snap-align:center;}
.day-pill .dow{font-size:10px;color:var(--txt3);font-weight:500;text-transform:uppercase;letter-spacing:.05em;}
.day-pill .day{font-family:'Montserrat',sans-serif;font-size:18px;font-weight:700;color:var(--txt);margin-top:2px;}
.day-pill.active{background:var(--red);}
.day-pill.active .dow,.day-pill.active .day{color:#fff;}

/* Tags */
.tag{display:inline-block;padding:3px 8px;border-radius:6px;font-size:10px;font-weight:600;letter-spacing:.03em;}
.tag-red{background:var(--red-gl);color:var(--red-br);border:1px solid rgba(192,57,43,.3);}
.tag-blue{background:rgba(52,152,219,.15);color:var(--blue);}
.tag-green{background:rgba(46,204,113,.15);color:var(--green);}
.tag-neutral{background:var(--card2);color:var(--txt2);}

/* Avatar */
.avatar-circle{width:56px;height:56px;border-radius:50%;background:var(--red);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-family:'Montserrat',sans-serif;font-size:18px;flex-shrink:0;}

/* Progress */
.progress{height:4px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden;}
.progress>div{height:100%;background:var(--red);border-radius:2px;transition:width .4s;}

/* Utility */
.row{display:flex;align-items:center;gap:12px;}
.between{display:flex;justify-content:space-between;align-items:center;}
.col{display:flex;flex-direction:column;}

/* Toast */
#toast{position:fixed;top:24px;left:50%;transform:translateX(-50%) translateY(-100px);background:var(--card);border:1px solid var(--brd);padding:12px 20px;border-radius:10px;font-size:13px;z-index:1000;transition:transform .25s;pointer-events:none;box-shadow:0 8px 24px rgba(0,0,0,.5);}
#toast.show{transform:translateX(-50%) translateY(0);}

/* Login screen */
#screen-login{padding:0;display:none;}
#screen-login.active{display:flex;flex-direction:column;justify-content:center;align-items:stretch;padding:40px 24px;}
#screen-picker{padding:0;display:none;}
#screen-picker.active{display:flex;flex-direction:column;padding:40px 24px;}
.picker-card{display:flex;align-items:center;gap:12px;background:var(--card);border:1px solid var(--brd);border-radius:14px;padding:14px;margin-bottom:10px;cursor:pointer;color:var(--txt);font-family:inherit;width:100%;text-align:left;transition:.15s;}
.picker-card:hover{background:var(--card2);border-color:var(--red-dk);}
#admin-banner{display:none;background:var(--red-gl);border-bottom:1px solid rgba(192,57,43,.25);padding:6px 16px;font-size:10px;color:var(--red-br);text-align:center;font-weight:700;letter-spacing:.05em;position:sticky;top:0;z-index:5;}
#admin-banner button{background:none;border:none;color:var(--red-br);text-decoration:underline;cursor:pointer;font:inherit;padding:0;margin-left:4px;}
.login-logo{text-align:center;margin-bottom:40px;}
.logo-lvl{width:110px;height:110px;margin:0 auto;background:var(--red-br);-webkit-mask:url('data:image/png;base64,') no-repeat center/contain;mask:url('data:image/png;base64,') no-repeat center/contain;}
.login-brand{font-family:'Montserrat',sans-serif;font-size:22px;font-weight:800;letter-spacing:.05em;margin-top:12px;}
.login-sub{font-size:12px;color:var(--txt3);letter-spacing:.15em;text-transform:uppercase;margin-top:4px;}
.login-form{display:flex;flex-direction:column;gap:14px;}
.login-form label{font-size:11px;color:var(--txt3);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:-4px;}
.login-form input{background:var(--input);border:1px solid var(--brd);border-radius:10px;padding:14px 16px;font-size:15px;color:var(--txt);font-family:inherit;outline:none;transition:.15s;}
.login-form input:focus{border-color:var(--red-dk);background:#1e1818;}
.login-hint{font-size:11px;color:var(--txt3);text-align:center;margin-top:16px;line-height:1.5;}
.login-demo{margin-top:20px;padding:12px;background:var(--card);border:1px solid var(--brd);border-radius:10px;font-size:10px;color:var(--txt3);line-height:1.7;}
.login-demo strong{color:var(--txt2);}

/* Timer */
.timer-huge{font-family:'Montserrat',sans-serif;font-size:92px;font-weight:900;line-height:1;letter-spacing:-.02em;}
.timer-bar{height:4px;background:rgba(255,255,255,.08);border-radius:2px;margin:24px 30px 8px;overflow:hidden;}
.timer-bar>div{height:100%;background:var(--red);border-radius:2px;transition:width .5s linear;}

/* Series table */
.series-row{display:grid;grid-template-columns:36px 1fr 1fr 1fr 42px;padding:10px 12px;border-bottom:1px solid var(--brd);align-items:center;transition:.15s;}
.series-row.current{background:var(--red-gl);}
.series-row.pending{opacity:.65;}
.series-row:last-child{border-bottom:none;}
.series-num{font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;}
.series-cell-btn{background:transparent;border:1px solid var(--brd);border-radius:6px;padding:5px 8px;color:var(--txt);font-weight:700;font-size:13px;font-family:'Montserrat',sans-serif;cursor:pointer;width:100%;text-align:left;transition:.15s;}
.series-cell-btn:hover{border-color:var(--red-dk);color:var(--red-br);}
.series-cell-btn.done{border-color:var(--red-dk);color:var(--red-br);}
.series-cell-input{background:var(--bg);border:1.5px solid var(--red-br);border-radius:6px;padding:5px 8px;color:var(--red-br);font-weight:700;font-size:13px;font-family:'Montserrat',sans-serif;width:100%;outline:none;}
.check-done{display:inline-flex;width:24px;height:24px;border-radius:50%;background:var(--green);color:#000;align-items:center;justify-content:center;}
.check-pending{display:inline-block;width:22px;height:22px;border-radius:50%;border:1.5px solid var(--txt3);}

/* Value card (exo screen) */
.val-card{background:var(--card);border:1px solid var(--brd);border-radius:12px;padding:12px 8px 10px;text-align:center;position:relative;cursor:pointer;transition:.15s;}
.val-card:hover{border-color:var(--red-dk);}
.val-card-hdr{display:flex;align-items:center;justify-content:center;gap:5px;margin-bottom:6px;}
.val-card-hdr span{font-size:9px;color:var(--txt3);text-transform:uppercase;letter-spacing:.08em;}
.val-card-val{font-family:'Montserrat',sans-serif;font-size:20px;font-weight:800;}
.val-card-val small{font-size:11px;color:var(--txt3);font-weight:500;}
.val-card-edit{position:absolute;top:8px;right:8px;color:var(--red-br);}

/* Edit modal */
.modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.7);z-index:100;display:none;align-items:center;justify-content:center;padding:20px;}
.modal-bg.active{display:flex;}
.modal{background:var(--card);border:1px solid var(--brd);border-radius:14px;padding:20px;width:100%;max-width:340px;animation:slideUp .2s ease;}
@keyframes slideUp{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}
.modal-title{font-family:'Montserrat',sans-serif;font-size:15px;font-weight:700;margin-bottom:4px;}
.modal-sub{font-size:11px;color:var(--txt3);margin-bottom:18px;}
.stepper{display:flex;align-items:center;gap:10px;background:var(--input);border-radius:12px;padding:6px;margin-bottom:18px;}
.stepper button{width:44px;height:44px;border-radius:8px;background:var(--card2);border:1px solid var(--brd);color:var(--txt);font-size:20px;cursor:pointer;font-family:inherit;}
.stepper button:hover{background:var(--red-gl);color:var(--red-br);border-color:var(--red-dk);}
.stepper .val{flex:1;text-align:center;font-family:'Montserrat',sans-serif;font-size:26px;font-weight:800;}
.stepper .val small{font-size:12px;color:var(--txt3);font-weight:500;display:block;margin-top:-4px;}

/* Session completion */
.session-done{text-align:center;padding:60px 30px;}
.session-done .big-check{width:80px;height:80px;border-radius:50%;background:var(--green);color:#000;display:inline-flex;align-items:center;justify-content:center;margin-bottom:20px;}
.session-done h2{font-family:'Montserrat',sans-serif;font-size:22px;font-weight:800;margin-bottom:8px;}
.session-done p{color:var(--txt3);font-size:14px;margin-bottom:24px;}

/* Menu rows */
.menu-row{display:flex;align-items:center;gap:14px;padding:14px 16px;border-bottom:1px solid var(--brd);cursor:pointer;transition:.15s;}
.menu-row:hover{background:var(--card2);}
.menu-row:last-child{border-bottom:none;}
.menu-icon{width:28px;height:28px;display:flex;align-items:center;justify-content:center;color:var(--red-br);flex-shrink:0;}
.menu-icon svg{width:18px;height:18px;}
.menu-label{flex:1;font-size:14px;font-weight:600;}
.menu-chevron{color:var(--txt3);}
</style>
</head>
<body>

<div id="app">

<!-- ========== LOGIN ========== -->
<div class="screen" id="screen-login">
  <div class="login-logo">
    <div class="logo-lvl"></div>
    <div class="login-brand">TIMOTHY LVL</div>
    <div class="login-sub">Espace élève</div>
  </div>

  <form class="login-form" onsubmit="handleLogin(event)">
    <label>Email</label>
    <input type="email" id="login-email" placeholder="ton.email@exemple.com" required autocomplete="email">
    <label>Code d'accès</label>
    <input type="text" id="login-code" placeholder="Ton code à 4 chiffres" required inputmode="numeric" pattern="[0-9]*" maxlength="4">
    <button type="submit" class="btn btn-p btn-block" style="margin-top:12px;padding:14px;font-size:14px;font-weight:700;">Me connecter</button>
  </form>

  <div class="login-hint">Code d'accès fourni par ton coach Timothy.</div>

  <div class="login-demo">
    <strong>Demo :</strong> Essaie <code>victoria@exemple.com</code> / <code>1234</code><br>
    ou <code>josue@exemple.com</code> / <code>2222</code>
  </div>
</div>

<!-- ========== ADMIN BANNER (visible only in admin stealth mode) ========== -->
<div id="admin-banner">
  MODE ADMIN · vu en tant que <span id="admin-banner-name">—</span>
  · <button onclick="goBackToPicker()">Changer d'élève</button>
</div>

<!-- ========== STUDENT PICKER (admin only) ========== -->
<div class="screen" id="screen-picker">
  <div class="login-logo">
    <div class="logo-lvl"></div>
    <div class="login-brand" style="margin-top:16px;">TIMOTHY LVL</div>
    <div class="login-sub" style="color:var(--red-br);">Mode admin — stealth</div>
  </div>
  <div style="text-align:center;margin:0 0 24px;font-size:13px;color:var(--txt2);">Choisis un élève pour voir son espace :</div>
  <div id="picker-list"></div>
  <button onclick="logout()" style="margin-top:16px;background:transparent;border:none;color:var(--txt3);font-size:12px;cursor:pointer;padding:12px;width:100%;font-family:inherit;">← Se déconnecter</button>
</div>

<!-- ========== ACCUEIL ========== -->
<div class="screen" id="screen-accueil">
  <div class="top-bar">
    <div>
      <div style="font-size:12px;color:var(--txt3);">Aujourd'hui ›</div>
      <h1 id="hello-msg">Bonjour 👋</h1>
    </div>
    <div class="icons">
      <button class="icon-btn" onclick="toast('Aucune nouvelle notification')" aria-label="Notifications">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
      </button>
    </div>
  </div>

  <!-- À faire aujourd'hui -->
  <div class="card" id="today-task-card">
    <div class="card-title">À faire aujourd'hui</div>
    <div id="today-task-body"></div>
  </div>

  <!-- Poids -->
  <div class="card">
    <div class="between" style="margin-bottom:6px;">
      <span style="font-family:'Montserrat',sans-serif;font-size:15px;font-weight:700;">Poids</span>
      <button class="btn btn-sm btn-ghost" onclick="openWeightEdit()">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
        Modifier
      </button>
    </div>
    <div style="font-family:'Montserrat',sans-serif;font-size:28px;font-weight:800;line-height:1.1;" id="w-current">—</div>
    <div style="font-size:11px;color:var(--txt3);margin-bottom:14px;" id="w-date">—</div>

    <div id="w-chart-wrap" style="margin-bottom:10px;"></div>

    <div class="between" style="font-size:11px;padding-top:12px;border-top:1px solid var(--brd);">
      <div>
        <div style="color:var(--txt3);font-size:9px;text-transform:uppercase;letter-spacing:.08em;">Départ</div>
        <div style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;margin-top:3px;" id="w-start">—</div>
      </div>
      <div style="text-align:center;">
        <div style="color:var(--txt3);font-size:9px;text-transform:uppercase;letter-spacing:.08em;">Évolution</div>
        <div style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;margin-top:3px;" id="w-evo">—</div>
      </div>
      <div style="text-align:right;">
        <div style="color:var(--txt3);font-size:9px;text-transform:uppercase;letter-spacing:.08em;">Objectif</div>
        <div style="font-family:'Montserrat',sans-serif;color:var(--red-br);font-weight:700;font-size:14px;margin-top:3px;" id="w-target">—</div>
      </div>
    </div>
  </div>

  <!-- Prochain rendez-vous -->
  <div class="card">
    <div class="card-title">Prochain rendez-vous</div>
    <div style="display:flex;align-items:center;gap:12px;padding-top:4px;">
      <div style="width:46px;height:46px;background:var(--red);border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;flex-shrink:0;">
        <span style="font-size:9px;font-weight:600;">AVR</span>
        <span style="font-family:'Montserrat',sans-serif;font-size:18px;font-weight:800;line-height:1;">19</span>
      </div>
      <div>
        <div style="font-size:13px;font-weight:600;">Bilan mensuel avec Timothy</div>
        <div style="font-size:11px;color:var(--txt3);">Dimanche · 10h00 · 30 min</div>
      </div>
    </div>
  </div>
</div>

<!-- ========== SPORT ========== -->
<div class="screen" id="screen-sport">
  <div class="top-bar">
    <div><h1>Entraînement</h1><div class="sub">Aujourd'hui</div></div>
  </div>

  <div class="date-row" id="sport-dates"></div>

  <div id="sport-sessions"></div>
</div>

<!-- ========== EXERCICE EN COURS ========== -->
<div class="screen screen-session" id="screen-exo">
  <!-- Top bar -->
  <div style="padding:14px 16px 12px;display:flex;align-items:center;justify-content:space-between;gap:10px;">
    <button class="icon-btn" onclick="confirmExitSession()" aria-label="Retour">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <div style="background:var(--card);padding:6px 14px;border-radius:20px;border:1px solid var(--brd);font-size:12px;">
      <span style="color:var(--txt3);">Durée séance</span>
      <strong style="margin-left:6px;font-family:'Montserrat',sans-serif;" id="exo-duration">00:00</strong>
    </div>
    <button class="icon-btn" onclick="nav('series')" aria-label="Vue liste">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <!-- Illustration exercice -->
  <div style="margin:0 16px 16px;background:var(--card);border:1px dashed rgba(255,255,255,.15);border-radius:14px;height:220px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;position:relative;">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--red-br)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:.8;">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <circle cx="9" cy="9" r="2"/>
      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
    </svg>
    <div style="text-align:center;padding:0 20px;">
      <div style="font-size:11px;font-weight:600;color:var(--txt2);">Photo de l'exercice</div>
      <div style="font-size:10px;color:var(--txt3);margin-top:3px;">Depuis la bibliothèque de Timothy</div>
    </div>
  </div>

  <!-- Nom + tags + chrono série -->
  <div style="padding:0 16px 12px;display:flex;justify-content:space-between;align-items:flex-start;gap:12px;">
    <div style="flex:1;">
      <div style="font-family:'Montserrat',sans-serif;font-size:17px;font-weight:800;" id="exo-name">—</div>
      <div style="margin-top:6px;" id="exo-tags"></div>
    </div>
  </div>

  <!-- 3 cartes modifiables -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:0 16px;">
    <div class="val-card" onclick="editValue('kg')">
