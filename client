function startDurationTimer(){
  if(durationInterval) clearInterval(durationInterval);
  const upd = () => {
    if(!sessionStartTs) return;
    const elapsed = Math.floor((Date.now() - sessionStartTs)/1000);
    const mm = String(Math.floor(elapsed/60)).padStart(2,'0');
    const ss = String(elapsed%60).padStart(2,'0');
    const txt = `${mm}:${ss}`;
    document.getElementById('exo-duration').textContent = txt;
    document.getElementById('repos-duration').textContent = txt;
    document.getElementById('series-duration').textContent = txt;
  };
  upd();
  durationInterval = setInterval(upd, 1000);
}

function confirmExitSession(){
  if(confirm('Quitter la séance ? Ta progression sera perdue.')){
    stopSession();
    nav('sport');
