function buildWeightChart(hist){
  const w=320,h=66,pad=10;
  const vals=hist.map(e=>e.val);
  let min=Math.min(...vals), max=Math.max(...vals);
  if(min===max){min-=1;max+=1;}
  const range=max-min;
  const n=hist.length;
  const xAt=i=>pad+i*(w-pad*2)/(n-1);
  const yAt=v=>h-pad-(v-min)/range*(h-pad*2);
  const pts=hist.map((e,i)=>`${xAt(i).toFixed(1)},${yAt(e.val).toFixed(1)}`);
  const line='M'+pts.join(' L');
  const area=`M${xAt(0)},${h} L${pts.join(' L')} L${xAt(n-1)},${h} Z`;
  const lastX=xAt(n-1), lastY=yAt(vals[n-1]);
  return `<svg viewBox="0 0 ${w} ${h}" width="100%" height="${h}" preserveAspectRatio="none" style="display:block;overflow:visible;">
    <defs><linearGradient id="wGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#e74c3c" stop-opacity="0.35"/>
      <stop offset="100%" stop-color="#e74c3c" stop-opacity="0"/>
    </linearGradient></defs>
    <path d="${area}" fill="url(#wGrad)"/>
    <path d="${line}" stroke="#e74c3c" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="${xAt(0)}" cy="${yAt(vals[0])}" r="3" fill="var(--txt3)"/>
    <circle cx="${lastX}" cy="${lastY}" r="4.5" fill="#0a0a0a" stroke="#e74c3c" stroke-width="2.2"/>
  </svg>`;
}

