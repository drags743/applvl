}

function stopSession(){
  activeSession = null;
  if(durationInterval){ clearInterval(durationInterval); durationInterval = null; }
  if(timerInterval){ clearInterval(timerInterval); timerInterval = null; }
}

function renderExo(){
  if(!activeSession) return;
  const ex = activeSession.exercises[activeExIdx];
  const ser = ex.series[activeSerIdx];
  document.getElementById('exo-name').textContent = `${activeExIdx+1}. ${ex.nom}`;
  document.getElementById('exo-tags').innerHTML = `
    <span class="tag tag-neutral">Série ${activeSerIdx+1} / ${ex.series.length}</span>
    <span class="tag tag-red" style="margin-left:4px;">${ex.muscle}</span>
    <span class="tag tag-neutral" style="margin-left:4px;">${ex.equipment}</span>`;
  document.getElementById('exo-kg').textContent = ser.kg;
  document.getElementById('exo-reps').textContent = ser.reps;
  document.getElementById('exo-rest').textContent = ser.rest;

  const lastEl = document.getElementById('exo-last-session');
  if(ex.last){
    lastEl.style.display = 'block';
    lastEl.innerHTML = `<strong style="color:var(--red-br);">Dernière séance :</strong> ${ex.last.reps} reps à ${ex.last.kg} kg`;
  } else { lastEl.style.display = 'none'; }
}

function validateAndRest(){
  if(!activeSession) return;
  const ex = activeSession.exercises[activeExIdx];
  const ser = ex.series[activeSerIdx];
  ser.kg_done = ser.kg;
  ser.reps_done = ser.reps;
  ser.done = true;
  ex.last = { kg: ser.kg, reps: ser.reps };

  // Prepare "Série précédente" display
  document.getElementById('prev-kg').textContent = ser.kg;
  document.getElementById('prev-reps').textContent = ser.reps;

  // Next-exercise preview
  let nextName='Fin de la séance', nextInfo='Dernière série';
  const nextSerIdx = activeSerIdx + 1;
  if(nextSerIdx < ex.series.length){
    nextName = ex.nom;
    const ns = ex.series[nextSerIdx];
    nextInfo = `Série ${nextSerIdx+1}/${ex.series.length} · ${ns.reps} reps · ${ns.kg} kg`;
  } else if(activeExIdx + 1 < activeSession.exercises.length){
    const nextEx = activeSession.exercises[activeExIdx+1];
    nextName = nextEx.nom;
    nextInfo = `Nouvel exercice · ${nextEx.series.length} séries`;
  }
  document.getElementById('next-name').textContent = nextName;
  document.getElementById('next-info').textContent = nextInfo;

  startRestTimer(ser.rest);
}

function skipSeries(){
  // Just move on without validating — user didn't do it or already logged
  advanceSeries();
  renderExo();
}

function skipRest(){
  stopRestTimer();
  advanceSeries();
  renderExo();
  nav('exo');
}

function advanceSeries(){
  if(!activeSession) return;
  activeSerIdx++;
  const ex = activeSession.exercises[activeExIdx];
  if(activeSerIdx >= ex.series.length){
    activeSerIdx = 0;
    activeExIdx++;
    if(activeExIdx >= activeSession.exercises.length){
      finishSession();
      return;
    }
  }
}

function prevSeries(){
  if(activeSerIdx > 0) activeSerIdx--;
  else if(activeExIdx > 0){ activeExIdx--; activeSerIdx = activeSession.exercises[activeExIdx].series.length - 1; }
  renderExo();
}

function finishSession(){
  stopSession();
  document.body.innerHTML = `<div id="app"><div class="screen active session-done">
    <div class="big-check"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
    <h2>Séance terminée !</h2>
    <p>Bravo, tu as complété ta séance. Tes performances ont été enregistrées.</p>
    <button class="btn btn-p btn-block" style="margin-top:10px;padding:14px;font-size:14px;font-weight:700;" onclick="location.reload()">Retour à l'accueil</button>
  </div></div>`;
}

/* ======================================================================
   REST TIMER (level 1 — Date.now() based, survives tab inactivity)
   ====================================================================== */
function startRestTimer(duration){
  restDuration = duration;
  restStartTs = Date.now();
  restPaused = false;
  nav('repos');
  updateRestDisplay();
  if(timerInterval) clearInterval(timerInterval);
  timerInterval = setInterval(updateRestDisplay, 250);
  // Unlock audio on user gesture (needed for iOS)
  unlockAudio();
}

function stopRestTimer(){
  if(timerInterval){ clearInterval(timerInterval); timerInterval = null; }
  restStartTs = null;
}

function updateRestDisplay(){
  if(restStartTs === null) return;
  const elapsed = restPaused
    ? restPausedAt
    : (Date.now() - restStartTs) / 1000;
  const remaining = Math.max(0, restDuration - elapsed);
  const mm = String(Math.floor(remaining/60)).padStart(2,'0');
  const ss = String(Math.floor(remaining%60)).padStart(2,'0');
  document.getElementById('timer-display').textContent = `${mm}:${ss}`;
  const pct = Math.min(100, (elapsed/restDuration)*100);
  document.getElementById('timer-bar-fill').style.width = pct + '%';
  document.getElementById('timer-elapsed').textContent = `${Math.floor(elapsed)} s / ${restDuration} s`;

  if(remaining <= 0){
    stopRestTimer();
    playAlert();
    if(navigator.vibrate) navigator.vibrate([200,100,200]);
    setTimeout(() => {
      advanceSeries();
      renderExo();
      nav('exo');
    }, 1200);
  }
}

function toggleRest(){
  if(restStartTs === null) return;
  const btn = document.getElementById('rest-toggle-btn');
  if(restPaused){
    // Resume: adjust restStartTs so elapsed stays the same
    restStartTs = Date.now() - restPausedAt * 1000;
    restPaused = false;
    btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';
  } else {
    // Pause: freeze at current elapsed
    restPausedAt = (Date.now() - restStartTs) / 1000;
    restPaused = true;
    btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
  }
}

function adjustRest(delta){
  if(restStartTs === null) return;
  restDuration = Math.max(5, restDuration + delta);
  updateRestDisplay();
}

function unlockAudio(){
  if(audioCtx) return;
  try{
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    // Silent buffer to prime
    const b = audioCtx.createBuffer(1, 1, 22050);
    const s = audioCtx.createBufferSource();
    s.buffer = b; s.connect(audioCtx.destination); s.start(0);
  }catch(e){ console.warn('Audio context unavailable', e); }
}

function playAlert(){
  try{
    if(!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const t0 = audioCtx.currentTime;
    // Triple beep
    [0, 0.22, 0.44].forEach(offset => {
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain); gain.connect(audioCtx.destination);
      osc.frequency.value = 880;
      osc.type = 'sine';
      gain.gain.setValueAtTime(0.0001, t0 + offset);
      gain.gain.exponentialRampToValueAtTime(0.4, t0 + offset + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.0001, t0 + offset + 0.18);
      osc.start(t0 + offset);
      osc.stop(t0 + offset + 0.2);
    });
  }catch(e){ console.warn('Alert failed:', e); }
}

/* ======================================================================
   EDIT VALUE (exo card)
   ====================================================================== */
function editValue(field){
  if(!activeSession) return;
  const ser = activeSession.exercises[activeExIdx].series[activeSerIdx];
  let title, sub, unit, step, cur;
  if(field === 'kg'){ title='Modifier la charge'; sub='Ajuste le poids que tu utilises'; unit='kg'; step=2.5; cur=ser.kg; }
  else if(field === 'reps'){ title='Modifier les répétitions'; sub='Indique le nombre de reps'; unit='reps'; step=1; cur=ser.reps; }
  else if(field === 'rest'){ title='Modifier le temps de repos'; sub='En secondes'; unit='sec'; step=15; cur=ser.rest; }
  else return;
  editContext = { field, origValue:cur, step, unit };
  document.getElementById('edit-title').textContent = title;
  document.getElementById('edit-sub').textContent = sub;
  document.getElementById('edit-val').textContent = cur;
  document.getElementById('edit-unit').textContent = unit;
  document.getElementById('edit-modal').classList.add('active');
}

function edit_adjust(dir){
  const el = document.getElementById('edit-val');
  let val = parseFloat(el.textContent);
  val = Math.max(0, val + dir * editContext.step);
  // Kg: allow decimals; reps/rest integer
  el.textContent = editContext.field === 'kg' ? val : Math.round(val);
}

function closeEdit(){
  document.getElementById('edit-modal').classList.remove('active');
}

function saveEdit(){
  if(!activeSession) return;
  const ser = activeSession.exercises[activeExIdx].series[activeSerIdx];
  const val = parseFloat(document.getElementById('edit-val').textContent);
  ser[editContext.field] = val;
  closeEdit();
  renderExo();
  toast('✓ Valeur mise à jour');
}

/* ======================================================================
   WEIGHT EDIT
   ====================================================================== */
function openWeightEdit(){
  const val = prompt('Poids actuel (kg) :', currentClient.poids.toFixed(1));
  if(val === null) return;
  const n = parseFloat(val.replace(',','.'));
  if(isNaN(n) || n < 20 || n > 250){ toast('Valeur invalide'); return; }
  currentClient.poids = n;
  const todayStr = new Date().toISOString().split('T')[0];
  const h = APP.weightHistory[currentClient.id];
  const last = h[h.length-1];
  if(last.date === todayStr) last.val = n;
  else h.push({date: todayStr, val: n});
  if(h.length > 12) h.shift();
  renderAccueil();
  toast('✓ Poids enregistré');
}

/* ======================================================================
   SERIES VIEW (tableau)
   ====================================================================== */
function renderSeriesView(){
  if(!activeSession) return;
  const ex = activeSession.exercises[activeExIdx];
  document.getElementById('series-name').textContent = ex.nom;
  document.getElementById('series-sub').textContent = `Exercice ${activeExIdx+1} · ${ex.muscle} · ${ex.equipment}`;

  const rowsEl = document.getElementById('series-rows');
  rowsEl.innerHTML = ex.series.map((s,i) => {
    const isCurrent = i === activeSerIdx;
    const cls = s.done ? '' : (isCurrent ? 'current' : 'pending');
    const checkEl = s.done
      ? `<span class="check-done"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>`
      : (isCurrent ? `<span style="display:inline-flex;width:24px;height:24px;border-radius:50%;border:1.5px solid var(--red-br);align-items:center;justify-content:center;"><span style="width:8px;height:8px;border-radius:50%;background:var(--red-br);"></span></span>` : `<span class="check-pending"></span>`);
    return `<div class="series-row ${cls}">
      <div class="series-num" ${isCurrent?'style="color:var(--red-br);"':''}>${i+1}</div>
      <div><button class="series-cell-btn ${s.done?'done':''}" onclick="seriesEdit(${i},'kg')">${s.kg} <span style="font-size:10px;font-weight:500;color:var(--txt3);">kg</span></button></div>
      <div><button class="series-cell-btn ${s.done?'done':''}" onclick="seriesEdit(${i},'reps')">${s.reps} <span style="font-size:10px;font-weight:500;color:var(--txt3);">reps</span></button></div>
      <div style="font-size:12px;color:${s.done?'var(--txt2)':'var(--txt3)'};">${s.rest} s</div>
      <div style="text-align:center;">${checkEl}</div>
    </div>`;
  }).join('');

  // Other exos preview
  const otherEl = document.getElementById('series-other-exos');
  const others = activeSession.exercises.slice(activeExIdx+1);
  if(others.length === 0){
    otherEl.innerHTML = '';
  } else {
    otherEl.innerHTML = `<div style="padding:0 16px 8px;font-size:10px;color:var(--txt3);font-weight:700;text-transform:uppercase;letter-spacing:.1em;">Prochains exercices</div>` +
      others.map((e,i) => `<div class="card" style="padding:12px;">
        <div class="row">
          <div style="width:40px;height:40px;background:var(--card2);border-radius:8px;display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--red-br)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 6.5h11v11h-11z"/><path d="M2 12h4.5"/><path d="M17.5 12H22"/><path d="M4 9v6"/><path d="M20 9v6"/></svg>
          </div>
          <div style="flex:1;">
            <div style="font-size:13px;font-weight:700;">${activeExIdx+2+i}. ${e.nom}</div>
            <div style="font-size:11px;color:var(--txt3);margin-top:2px;">${e.series.length} séries · ${e.muscle} · ${e.equipment}</div>
          </div>
          <span style="color:var(--txt3);">›</span>
        </div></div>`).join('');
  }
}

function seriesEdit(serIdx, field){
  if(!activeSession) return;
  const ser = activeSession.exercises[activeExIdx].series[serIdx];
  const cur = ser[field];
  const unit = field === 'kg' ? 'kg' : 'reps';
  const val = prompt(`Nouvelle valeur (${unit}) :`, cur);
  if(val === null) return;
  const n = parseFloat(val.replace(',','.'));
  if(isNaN(n) || n < 0){ toast('Valeur invalide'); return; }
  ser[field] = field === 'kg' ? n : Math.round(n);
  renderSeriesView();
  toast('✓ Sauvegardé');
}

function addSeries(){
  if(!activeSession) return;
  const ex = activeSession.exercises[activeExIdx];
  const last = ex.series[ex.series.length-1];
  ex.series.push({kg:last.kg, reps:last.reps, rest:last.rest, kg_done:null, reps_done:null, done:false});
  renderSeriesView();
  toast('✓ Série ajoutée');
}

// Hook renderSeriesView when nav('series')
const _origNav = nav;
nav = function(s){ _origNav(s); if(s === 'series') renderSeriesView(); };

/* ======================================================================
   RENDER — NUTRITION
   ====================================================================== */
function renderNutrition(){
  const c = currentClient;
  // Dates
  const today = new Date();
  const dates = [];
  for(let i=-3;i<=3;i++){ const d=new Date(today); d.setDate(d.getDate()+i); dates.push(d); }
  document.getElementById('nut-dates').innerHTML = dates.map(d => {
    const isToday = d.toDateString() === today.toDateString();
    const dow = d.toLocaleDateString('fr-FR',{weekday:'short'}).replace('.','').slice(0,3);
    return `<button class="day-pill ${isToday?'active':''}"><span class="dow">${dow}</span><span class="day">${d.getDate()}</span></button>`;
  }).join('');

  // KCal ring/stats
  document.getElementById('kcal-remain').textContent = c.kcal;
  document.getElementById('kcal-eaten').textContent = '0';
  document.getElementById('kcal-burned').textContent = '0';

  // Macros
  document.getElementById('m-gluc').textContent = `0 / ${c.gluc} g`;
  document.getElementById('m-prot').textContent = `0 / ${c.prot} g`;
  document.getElementById('m-lip').textContent  = `0 / ${c.lip} g`;

  // Meals — default distribution
  const mealsEl = document.getElementById('nut-meals');
  const meals = [
    {nom:'Petit-déjeuner', pct:.3},
    {nom:'Déjeuner',       pct:.4},
    {nom:'Dîner',          pct:.25},
    {nom:'Collation',      pct:.05}
  ];
  mealsEl.innerHTML = meals.map(m => {
    const target = Math.round(c.kcal * m.pct);
    return `<div class="card" style="padding:12px 14px;margin-bottom:8px;">
      <div class="between">
        <div>
          <div style="font-size:13px;font-weight:700;">${m.nom}</div>
          <div style="font-size:11px;color:var(--txt3);margin-top:2px;">Aucun élément</div>
        </div>
        <div style="text-align:right;"><strong style="font-family:'Montserrat',sans-serif;font-size:15px;">0</strong> <span style="color:var(--txt3);font-size:11px;">/ ${target} kcal</span></div>
      </div>
    </div>`;
  }).join('');

  // Hydratation — persist per day in localStorage
  renderHydration();
}

function hydraKey(){ return 'applvl.hydra.' + currentClient.id + '.' + new Date().toISOString().split('T')[0]; }

function renderHydration(){
  const v = +(localStorage.getItem(hydraKey()) || 0);
  const target = 2.5;
  const pct = Math.min(100, Math.round(v/target*100));
  document.getElementById('hydra-val').textContent = v.toFixed(2) + ' L';
  document.getElementById('hydra-pct').textContent = pct + '%';
  document.getElementById('hydra-bar').style.width = pct + '%';
}

function addWater(l){
  const cur = +(localStorage.getItem(hydraKey()) || 0);
  const next = +(cur + l).toFixed(2);
  localStorage.setItem(hydraKey(), next);
  renderHydration();
  toast(`+${l*1000} ml`);
}

