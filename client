   RENDER — PROFIL
   ====================================================================== */
function renderProfil(){
  const c = currentClient;
  document.getElementById('p-avatar').textContent = (c.prenom[0]+c.nom[0]).toUpperCase();
  document.getElementById('p-avatar').style.background = c.color || 'var(--red)';
